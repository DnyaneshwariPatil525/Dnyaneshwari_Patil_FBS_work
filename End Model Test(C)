#include<stdio.>
 void main()
  {
    int no1,no2,i,j,sum=0;
    int flag;
    printf("Enter Number 1:");
    scanf("%d",&no1);
    printf("Enter Number 2:");
    scanf("%d",&no2);

    for(i=no1;i<=no2;i++)
     {
       if(i<2)
         continue;
        flag=1;
         for(j=2;j<i/2;i++)
          {
           if(i%j == 0)
             {
               flag =0;
               break;
              }
           }
        if(flag == 1)
            sum=sum+i;
    } 
    print("Sum Of Prime Number : %d",sum);
}

