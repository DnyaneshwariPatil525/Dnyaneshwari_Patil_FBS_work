1. WAP to calculate electricity bill.
For 1–50 units → 30 Rs/unit, For 51–150 units → 40 Rs/unit ,For 151 and above units → 50 Rs/unit
#include<stdio.h>
void main()
{
	int unit,rate;
	float bill;
	
	printf("Enter a unit:");
	scanf("%d",&unit);
	
	if(unit>=1 && unit<=50)
	{
		rate=30;
	}
	else if(unit>=51 && unit<=150)
	{
		rate=40;
	}
	else
	{
		rate=50;
	}
	bill=unit*rate;
	printf("Electricity Bill = %f",bill);
}

2. WAP to check if a number is positive, negative or neutral (0).
#include<stdio.h>
void main()
{
	int no;
	printf("Enter a Number:");
	scanf("%d",&no);
	
	if(no>0)
	{
		printf("Number is Positive");
	}
	else if(no<0)
	{
		printf("Number is Negative");
		
	}
	else
	{
		printf("Number is neutral");
	}
}
