3. Sum of numbers in given range. Find sum of numbers from start to end.
#include<stdio.h>
void main()
{
	int start=1 , end=5 , sum=0;
	
	while(start <= end)
	{
		sum = sum+start;
		start++;
	}
	printf("Sum = %d",sum);
}

4. Check the given number is prime or not.
#include<stdio.h>
void main()
{
	int n=7, i=2, flag=0;
	
	while(i<n)
	{
		if(n % i == 0)
		{
	    	flag=1;
		    break;
    	}
	    i++;
	}
	if(flag == 0)
	  printf("Prime");
	else
	   printf("Not Prime");  
}

5. Check the given number is Armstrong number or not.
#include<stdio.h>
void main()
{
	int n=153;
	int i,rem,sum=0;
	
	i=n;
	while(i>0)
	{
		rem = i %10;
		sum += rem*rem*rem;
		i /= 10;
	}
	if(sum == n)
	printf("Armstrong");
	else
	printf("Not Armstrong");
}

