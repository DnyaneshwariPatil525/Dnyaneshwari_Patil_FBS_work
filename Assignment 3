7. Find factorial of given number.
#include<stdio.h>
void main()
{
	int  no = 5;
	int fact=1;
	while(no > 0)
	{
		fact = fact * no;
		no--;
	}
	printf("Factorial = %d",fact);
}

8. Check the given number is Strong number or not.
#include <stdio.h>
void main() {
    int n = 145;
	int temp, rem;
	int  sum = 0, i, fact;

    temp = n;

    while(temp > 0) 
	{
        rem = temp % 10;
        fact = 1;

        i = 1;
        while(i <= rem)
		 {
            fact *= i;
            i++;
         }

        sum += fact;
        temp /= 10;
    }

    if(sum == n)
        printf("Strong");
    else
        printf("Not Strong");

}

9. Check the given number is Palindrome number or not.
#include <stdio.h>
void main() {
    int n = 121, temp, rem, rev = 0;

    temp = n;

    while(temp > 0) 
	{
        rem = temp % 10;
        rev = rev * 10 + rem;
        temp /= 10;
    }

    if(rev == n)
        printf("Palindrome");
    else
        printf("Not Palindrome");
}

