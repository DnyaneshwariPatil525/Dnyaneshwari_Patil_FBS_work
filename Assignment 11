mystrrev()
#include<stdio.h>
void mystrrev(char str[]);
void main()
{
    char str[50];

    printf("Enter String : ");
    scanf(" %[^\n]",str);

    mystrrev(str);

    printf("Reverse String = %s",str);
}
void mystrrev(char str[])
{
    int i=0,j;
    char temp;

    while(str[i]!='\0')
        i++;

    j=i-1;
    i=0;

    while(i<j)
    {
        temp=str[i];
        str[i]=str[j];
        str[j]=temp;

        i++;
        j--;
    }
}

