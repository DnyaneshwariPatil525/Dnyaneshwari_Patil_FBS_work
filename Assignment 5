 1. Print a solid square pattern (n = 4)
* * * *
* * * *
* * * *
* * * *
#include<stdio.h>
void main()
{
	int i,j,no;
	
	printf("Enter Number:");
	scanf("%d",&no);
	
	for(i=1;i<=no;i++)
	{
		for(j=1;j<=no;j++)
		{
			printf("* ");
		}
		printf("\n");
	}
}

