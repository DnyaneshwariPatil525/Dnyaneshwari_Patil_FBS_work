    if(num % 2 == 0)
        printf("Even Number");
    else
        printf("Odd Number");
}

Q2. Write a program to check given 3 digit number is palindrome or not.
#include <stdio.h>
void main()
{
    int num=121, rev, a, b, c;
    a = num / 100;
    b = (num / 10) % 10;
    c = num % 10;

    rev = c * 100 + b * 10 + a;

    if(num == rev)
        printf("Palindrome Number");
    else
        printf("Not a Palindrome Number");
}

Q3. Write a program to check whether a given year is a leap year.
#include <stdio.h>
void main()
{
    int year=2017;

    if((year % 4 == 0 && year % 100 != 0) || (year % 400 == 0))
        printf("Leap Year");
    else
        printf("Not a Leap Year"); 
}

