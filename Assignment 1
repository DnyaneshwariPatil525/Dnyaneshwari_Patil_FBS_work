Q6. Write a program to check whether a given character is uppercase or lowercase.
#include <stdio.h>
void main()
{
    char ch = 'D';

    if(ch >= 'A' && ch <= 'Z')
        printf("Uppercase");
    else if(ch >= 'a' && ch <= 'z')
        printf("Lowercase");
    else
        printf("Not an Alphabet");
}

Q7. Calculating total salary based on basic. If basic <= 5000, DA, TA and HRA will be 10%, 20% and 25% respectively; otherwise DA, TA and HRA will be 15%, 25% and 30% respectively.
#include <stdio.h>
int main()
{
    float basic = 4000, da, ta, hra, total;

    if(basic <= 5000)
    {
        da = basic * 10 / 100;
        ta = basic * 20 / 100;
        hra = basic * 25 / 100;
    }
    else
    {
        da = basic * 15 / 100;
        ta = basic * 25 / 100;
        hra = basic * 30 / 100;
    }

    total = basic + da + ta + hra;

    printf("Total Salary = %f", total);
}
