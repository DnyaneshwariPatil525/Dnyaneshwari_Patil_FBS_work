1. Find minimum and maximum number in array.
#include<stdio.h>
#include<stdlib.h>
void main()
{
    int *arr;
    int n, i;
    int min, max;

    printf("Enter size of array: ");
    scanf("%d",&n);

    arr = (int *)malloc(n * sizeof(int));

    if(arr == NULL)
    {
        printf("Memory allocation failed");
        return;
    }

    printf("Enter %d elements:\n", n);

    for(i=0; i<n; i++)
    {
        scanf("%d",&arr[i]);
    }

    min = max = arr[0];

    for(i=1; i<n; i++)
    {
        if(arr[i] < min)
            min = arr[i];

        if(arr[i] > max)
            max = arr[i];
    }

    printf("Minimum = %d\n", min);
    printf("Maximum = %d\n", max);

    free(arr);
}

