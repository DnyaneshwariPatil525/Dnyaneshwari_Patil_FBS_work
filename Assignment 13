8. Merge two arrays.
#include<stdio.h>
#include<stdlib.h>
void main()
{
    int *a,*b,*c,n,i;

    printf("Enter size: ");
    scanf("%d",&n);

    a=(int*)malloc(n*sizeof(int));
    b=(int*)malloc(n*sizeof(int));
    c=(int*)malloc(2*n*sizeof(int));

    printf("Enter First Array:\n");
    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    printf("Enter Second Array:\n");
    for(i=0;i<n;i++)
        scanf("%d",&b[i]);

    for(i=0;i<n;i++)
        c[i]=a[i];

    for(i=0;i<n;i++)
        c[n+i]=b[i];

    printf("Merged Array:\n");

    for(i=0;i<2*n;i++)
        printf("%d ",c[i]);

    free(a);
    free(b);
    free(c);
}

