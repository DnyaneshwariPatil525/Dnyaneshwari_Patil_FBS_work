6. Accept array and print only prime numbers of array.
#include<stdio.h>
#include<stdlib.h>
void main()
{
    int *arr,n,i,j,count;

    printf("Enter size: ");
    scanf("%d",&n);

    arr=(int*)malloc(n*sizeof(int));

    printf("Enter elements:\n");

    for(i=0;i<n;i++)
        scanf("%d",&arr[i]);

    printf("Prime Numbers:\n");

    for(i=0;i<n;i++)
    {
        count=0;

        for(j=1;j<=arr[i];j++)
        {
            if(arr[i]%j==0)
                count++;
        }

        if(count==2)
            printf("%d ",arr[i]);
    }

    free(arr);
}

7. Take two arrays and add them into a third array.
   Example:
   arr[5] = {1, 2, 3, 4, 5}
   brr[5] = {10, 20, 30, 40, 50}
   crr[5] = {11, 22, 33, 44, 55}
