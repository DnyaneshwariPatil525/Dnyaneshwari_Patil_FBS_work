1. Write a program to scan a string from the user, then scan a single character and search it in the accepted string.
#include<stdio.h>
void search( char txt[] ,char lett);
void main()
{
	char str[50];
	char ch;
	
	printf("Enter String: ");
	scanf("%[^\n]",str);
	
	printf("Enter Character: ");
	scanf(" %c",&ch);
	
	search(str,ch);
}

void search( char txt[] ,char lett)
{
	int i ,flag=0;
	
	for(i=0;txt[i] != '\0';i++)
	{
		if(txt[i] == lett)
		{
			flag = 1;
			break;
		}
	}
	if(flag == 1)
	   printf("Character Found");
	else
	   printf("Character Not Found");   
}

