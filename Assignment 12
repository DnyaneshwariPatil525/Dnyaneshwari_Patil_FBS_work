7. WAP to remove the characters of odd index values in a string.
#include<stdio.h>
void removeOdd(char txt[]);
void main()
{
    char str[50];

    printf("Enter String: ");
    scanf(" %[^\n]", str);

    removeOdd(str);

    printf("New String = %s", str);
}

void removeOdd(char txt[])
{
    int i, j = 0;
    char temp[50];

    for(i = 0; txt[i] != '\0'; i++)
    {
        if(i % 2 == 0)
        {
            temp[j] = txt[i];
            j++;
        }
    }

    temp[j] = '\0';

    for(i = 0; temp[i] != '\0'; i++)
    {
        txt[i] = temp[i];
    }

    txt[i] = '\0';
}

8. WAP to calculate the number of words present in a string.
#include<stdio.h>
void countWord(char txt[]);
void main()
{
    char str[100];

    printf("Enter String: ");
    scanf(" %[^\n]", str);

    countWord(str);
}

void countWord(char txt[])
{
    int i, count = 1;

    if(txt[0] == '\0')
    {
        printf("Total Words = 0");
        return;
    }

    for(i = 0; txt[i] != '\0'; i++)
    {
        if(txt[i] == ' ' && txt[i+1] != ' ' && txt[i+1] != '\0')
        {
            count++;
        }
    }

    printf("Total Words = %d", count);
}

9. WAP to take in two strings and display the larger string without using built-in functions.
#include<stdio.h>
void largerString(char first[], char second[]);
void main()
{
    char str1[50], str2[50];

    printf("Enter First String: ");
    scanf(" %[^\n]", str1);

    printf("Enter Second String: ");
    scanf(" %[^\n]", str2);

    largerString(str1, str2);
}

void largerString(char first[], char second[])
{
    int i = 0, j = 0;

    while(first[i] != '\0')
        i++;

    while(second[j] != '\0')
        j++;

    if(i > j)
        printf("Larger String = %s", first);
    else if(j > i)
        printf("Larger String = %s", second);
    else
        printf("Both Strings are of Equal Length");
}

10. Write a program to check whether a string is palindrome or not.
#include<stdio.h>
#include<string.h>
void palindrome(char text[]);
void main()
{
    char str[50];

    printf("Enter String: ");
    scanf(" %[^\n]", str);

    palindrome(str);
}

void palindrome(char text[])
{
    int i, len, flag = 1;

    len = strlen(text);

    for(i = 0; i < len / 2; i++)
    {
        if(text[i] != text[len - 1 - i])
        {
            flag = 0;
            break;
        }
    }

    if(flag == 1)
        printf("String is Palindrome");
    else
        printf("String is Not Palindrome");
}
