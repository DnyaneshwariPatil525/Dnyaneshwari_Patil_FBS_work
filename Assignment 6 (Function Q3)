5. Write a menu-driven program to take a number from the user and perform the following operations:

   1. To check whether the number is even or odd.
   2. To check whether the number is prime or not.
   3. To check whether the number is palindrome or not.
   4. To check whether the number is positive, negative, or zero.
   5. To reverse a number.
   6. To find the sum of digits.
Type 1
#include<stdio.h>

void evenOdd();
void prime();
void palindrome();
void sign();
void reverse();
void sumDigits();

void main()
{
    int choice;

    do
    {
        printf("\n------ MENU ------");
        printf("\n1. Even or Odd");
        printf("\n2. Prime or Not Prime");
        printf("\n3. Palindrome or Not");
        printf("\n4. Positive, Negative or Zero");
        printf("\n5. Reverse Number");
        printf("\n6. Sum of Digits");
        printf("\n7. Exit");

        printf("\nEnter your choice : ");
        scanf("%d",&choice);

        switch(choice)
        {
            case 1:
                evenOdd();
                break;

            case 2:
                prime();
                break;

            case 3:
                palindrome();
                break;

            case 4:
                sign();
                break;

            case 5:
                reverse();
                break;

            case 6:
                sumDigits();
                break;

            case 7:
                printf("\nProgram Ended...");
                break;

            default:
                printf("\nInvalid Choice");
        }

    }while(choice!=7);
}

void evenOdd()
{
    int n;

    printf("\nEnter Number : ");
    scanf("%d",&n);

    if(n%2==0)
        printf("Even Number");
    else
        printf("Odd Number");
}

void prime()
{
    int n,i,count=0;

    printf("\nEnter Number : ");
    scanf("%d",&n);

    for(i=1;i<=n;i++)
    {
        if(n%i==0)
            count++;
    }

    if(count==2)
        printf("Prime Number");
    else
        printf("Not Prime Number");
}

void palindrome()
{
    int n,num,rem,rev=0;

    printf("\nEnter Number : ");
    scanf("%d",&n);

    num=n;

    while(n>0)
    {
        rem=n%10;
        rev=rev*10+rem;
        n=n/10;
    }

    if(num==rev)
        printf("Palindrome Number");
    else
        printf("Not Palindrome Number");
}

void sign()
{
    int n;

    printf("\nEnter Number : ");
    scanf("%d",&n);

    if(n>0)
        printf("Positive Number");
    else if(n<0)
        printf("Negative Number");
    else
        printf("Zero");
}

void reverse()
{
    int n,rem,rev=0;

    printf("\nEnter Number : ");
    scanf("%d",&n);

    while(n>0)
    {
        rem=n%10;
        rev=rev*10+rem;
        n=n/10;
    }

    printf("Reverse = %d",rev);
}

void sumDigits()
{
    int n,rem,sum=0;

    printf("\nEnter Number : ");
    scanf("%d",&n);

    while(n>0)
    {
        rem=n%10;
        sum=sum+rem;
        n=n/10;
    }

    printf("Sum of Digits = %d",sum);
}
