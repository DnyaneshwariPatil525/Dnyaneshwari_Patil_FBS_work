1. Print Armstrong numbers in the given range 1 to n.
Type 1
#include<stdio.h>
void armstrong();
void main()
{
    armstrong();
}

void armstrong()
{
    int n, i, num, rem, sum;

    printf("Enter the value of n : ");
    scanf("%d", &n);

    printf("Armstrong numbers from 1 to %d are:\n", n);

    for(i = 1; i <= n; i++)
    {
        num = i;
        sum = 0;

        while(num > 0)
        {
            rem = num % 10;
            sum = sum + (rem * rem * rem);
            num = num / 10;
        }

        if(sum == i)
        {
            printf("%d ", i);
        }
    }
}
