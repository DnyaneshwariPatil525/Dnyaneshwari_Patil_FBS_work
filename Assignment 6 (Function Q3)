4. Print Strong numbers in the given range 1 to n.
Type 1
#include<stdio.h>
void strong();
void main()
{
    strong();
}

void strong()
{
    int n, i, num, rem, sum, fact;

    printf("Enter the value of n : ");
    scanf("%d",&n);

    printf("Strong numbers from 1 to %d are:\n", n);

    for(i=1; i<=n; i++)
    {
        num = i;
        sum = 0;

        while(num > 0)
        {
            rem = num % 10;
            fact = 1;

            while(rem > 0)
            {
                fact = fact * rem;
                rem--;
            }

            sum = sum + fact;
            num = num / 10;
        }

        if(sum == i)
        {
            printf("%d ", i);
        }
    }
}
