1. Find minimum and maximum number in array.
#include<stdio.h>
void main()
{
    int a[5],i,min,max;

    printf("Enter elements:");
    for(i=0;i<5;i++)
        scanf("%d",&a[i]);

    min=a[0];
    max=a[0];

    for(i=1;i<5;i++)
    {
        if(a[i]>max)
            max=a[i];

        if(a[i]<min)
            min=a[i];
    }

    printf("Maximum = %d\n",max);
    printf("Minimum = %d",min);
}

2. Search the given number in array.
#include<stdio.h>
void main()
{
    int a[5],i,no;
	int flag=0;

    printf("Enter elements:");
    for(i=0;i<5;i++)
        scanf("%d",&a[i]);

