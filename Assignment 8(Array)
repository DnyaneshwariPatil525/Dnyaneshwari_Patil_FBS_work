}

6. Accept array and print only prime numbers of array.
#include<stdio.h>
void main()
{
    int a[10],i,j,count;

    printf("Enter elements:");
    for(i=0;i<10;i++)
        scanf("%d",&a[i]);

    printf("Prime Numbers:");

    for(i=0;i<10;i++)
    {
        count=0;

        for(j=1;j<=a[i];j++)
        {
            if(a[i]%j==0)
                count++;
        }

        if(count==2)
            printf("%d ",a[i]);
    }
}

7. Take two arrays and add them into a third array.
Example:
   arr[5] = {1, 2, 3, 4, 5}
   brr[5] = {10, 20, 30, 40, 50}
   crr[5] = {11, 22, 33, 44, 55}
#include<stdio.h>
void main()
{
    int a[5],b[5],c[5],i;

