8. Merge two arrays.
#include<stdio.h>
void main()
{
    int a[5],b[5],c[10],i;

    printf("Enter first array:");
    for(i=0;i<5;i++)
        scanf("%d",&a[i]);

    printf("Enter second array:");
    for(i=0;i<5;i++)
        scanf("%d",&b[i]);

    for(i=0;i<5;i++)
        c[i]=a[i];

    for(i=0;i<5;i++)
        c[i+5]=b[i];

    printf("Merged Array:");

    for(i=0;i<10;i++)
        printf("%d ",c[i]);
}

9. Reverse the given array.
#include<stdio.h>
void main()
{
    int a[5],i;

    printf("Enter elements:");
    for(i=0;i<5;i++)
        scanf("%d",&a[i]);

    printf("Reverse Array:");

    for(i=4;i>=0;i--)
