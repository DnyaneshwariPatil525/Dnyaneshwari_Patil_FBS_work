4. Find odd and even among the numbers.
#include<stdio.h>
void main()
{
    int a[5],i;

    printf("Enter elements:");
    for(i=0;i<5;i++)
        scanf("%d",&a[i]);

    printf("Even Numbers:");
    for(i=0;i<5;i++)
    {
        if(a[i]%2==0)
            printf("%d ",a[i]);
    }

    printf("\nOdd Numbers:");
    for(i=0;i<5;i++)
    {
        if(a[i]%2!=0)
            printf("%d ",a[i]);
    }
}

5. Print alternate elements in array.
