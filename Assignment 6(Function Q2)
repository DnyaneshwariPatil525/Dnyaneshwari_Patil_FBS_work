    int choice;

    do
    {
        printf("\n------ MENU ------");
        printf("\n1. Even or Odd");
        printf("\n2. Prime or Not Prime");
        printf("\n3. Palindrome or Not");
        printf("\n4. Positive, Negative or Zero");
        printf("\n5. Reverse Number");
        printf("\n6. Sum of Digits");
        printf("\n7. Exit");

        printf("\nEnter your choice : ");
        scanf("%d",&choice);

        switch(choice)
        {
            case 1:
                evenOdd();
                break;

            case 2:
                prime();
                break;

            case 3:
                palindrome();
                break;

            case 4:
                sign();
                break;

            case 5:
                reverse();
                break;

            case 6:
                sumDigits();
                break;

            case 7:
                printf("\nProgram Ended...");
                break;

            default:
                printf("\nInvalid Choice");
        }

    }while(choice!=7);
}

void evenOdd()
{
    int n;

    printf("\nEnter Number : ");
    scanf("%d",&n);

    if(n%2==0)
        printf("Even Number");
    else
        printf("Odd Number");
}

void prime()
{
    int n,i,count=0;

    printf("\nEnter Number : ");
    scanf("%d",&n);

    for(i=1;i<=n;i++)
    {
        if(n%i==0)
            count++;
    }

    if(count==2)
        printf("Prime Number");
    else
        printf("Not Prime Number");
}

void palindrome()
{
    int n,num,rem,rev=0;

    printf("\nEnter Number : ");
    scanf("%d",&n);

    num=n;

    while(n>0)
    {
        rem=n%10;
        rev=rev*10+rem;
        n=n/10;
    }

    if(num==rev)
        printf("Palindrome Number");
    else
        printf("Not Palindrome Number");
}

