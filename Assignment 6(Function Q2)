#include<stdio.h>

void evenOdd(int);
void prime(int);
void palindrome(int);
void sign(int);
void reverse(int);
void sumDigits(int);

void main()
{
    int n, choice;

    printf("Enter Number : ");
    scanf("%d",&n);

    do
    {
        printf("\n------ MENU ------");
        printf("\n1. Even or Odd");
        printf("\n2. Prime or Not Prime");
        printf("\n3. Palindrome or Not");
        printf("\n4. Positive, Negative or Zero");
        printf("\n5. Reverse Number");
        printf("\n6. Sum of Digits");
        printf("\n7. Exit");

        printf("\nEnter your choice : ");
        scanf("%d",&choice);

        switch(choice)
        {
            case 1:
                evenOdd(n);
                break;

            case 2:
                prime(n);
                break;

            case 3:
                palindrome(n);
                break;

            case 4:
                sign(n);
                break;

            case 5:
                reverse(n);
                break;

            case 6:
                sumDigits(n);
                break;

            case 7:
                printf("\nProgram Ended...");
                break;

            default:
                printf("\nInvalid Choice");
        }

    }while(choice!=7);
}

void evenOdd(int n)
{
    if(n%2==0)
        printf("Even Number");
    else
        printf("Odd Number");
}

void prime(int n)
{
    int i, count=0;

    for(i=1; i<=n; i++)
    {
        if(n%i==0)
            count++;
    }

    if(count==2)
        printf("Prime Number");
    else
        printf("Not Prime Number");
}

void palindrome(int n)
{
    int num, rem, rev=0;

    num=n;

    while(n>0)
    {
        rem=n%10;
        rev=rev*10+rem;
        n=n/10;
    }

    if(num==rev)
        printf("Palindrome Number");
    else
        printf("Not Palindrome Number");
}

void sign(int n)
{
    if(n>0)
        printf("Positive Number");
    else if(n<0)
        printf("Negative Number");
    else
        printf("Zero");
}

void reverse(int n)
{
    int rem, rev=0;

    while(n>0)
    {
        rem=n%10;
        rev=rev*10+rem;
        n=n/10;
    }

    printf("Reverse = %d",rev);
}

void sumDigits(int n)
{
    int rem, sum=0;

    while(n>0)
    {
        rem=n%10;
        sum=sum+rem;
        n=n/10;
    }

    printf("Sum of Digits = %d",sum);
}

